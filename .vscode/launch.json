{
  "version": "0.2.0",
  "configurations": [
    {
        "type": "node",
        "request": "launch",
        "name": "Iniciar servidor Next.js",
        "runtimeExecutable": "pnpm",
        "runtimeArgs": ["dev"],
        "cwd": "${workspaceFolder}/ensinos/",
        "skipFiles": ["<node_internals>/**", "node_modules/**"]
    },
    {
        "type": "msedge",
        "request": "launch",
        "name": "Abrir Edge",
        "url": "http://localhost:3000",
        "webRoot": "${workspaceFolder}/ensinos/",
        "sourceMaps": true,
        "resolveSourceMapLocations": [
            "${workspaceFolder}/ensinos/**",
            "!**/node_modules/**"
        ]
    }
  ],
  "compounds": [
    {
        "name": "Debug Next.js + Edge",
        "configurations": ["Iniciar servidor Next.js", "Abrir Edge"]
    }
  ]
}
